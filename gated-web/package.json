{
  "name": "gated-web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "devbuild": "vite build --mode development --minify false",
    "watch": "vite build -w --mode development --minify false",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:schema:gateway": "cargo run -p gated-protocol-http > src/features/gateway/lib/openapi-schema.json",
    "openapi:schema:admin": "cargo run -p gated-admin > src/features/admin/lib/openapi-schema.json",
    "openapi:client:gateway": "openapi-generator-cli generate -g typescript-fetch -i src/features/gateway/lib/openapi-schema.json -o src/features/gateway/lib/api-client -p npmName=gated-gateway-api-client -p useSingleRequestParameter=true && cd src/features/gateway/lib/api-client && bun i typescript@5 && bun i && bunx tsc --target esnext --module esnext && rm -rf src tsconfig.json",
    "openapi:client:admin": "openapi-generator-cli generate -g typescript-fetch -i src/features/admin/lib/openapi-schema.json -o src/features/admin/lib/api-client -p npmName=gated-admin-api-client -p useSingleRequestParameter=true && cd src/features/admin/lib/api-client && bun i typescript@5 && bun i && bunx tsc --target esnext --module esnext && rm -rf src tsconfig.json",
    "openapi:tests-sdk": "openapi-generator-cli generate -g python -i src/features/admin/lib/openapi-schema.json -o ../tests/api_sdk",
    "openapi": "bun run openapi:schema:admin && bun run openapi:schema:gateway && bun run openapi:client:admin && bun run openapi:client:gateway",
    "postinstall": "bun run openapi:client:gateway && bun run openapi:client:admin"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "copy-text-to-clipboard": "^3.2.2",
    "date-fns": "^4.1.0",
    "format-duration": "^3.0.2",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.511.0",
    "natural-orderby": "^5.0.0",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router": "^7.13.1",
    "tailwind-merge": "^3.3.0",
    "thenby": "^1.3.4",
    "tw-animate-css": "^1.3.4",
    "ua-parser-js": "^2.0.9",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@eslint-react/eslint-plugin": "^2",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/work-sans": "^5.2.8",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ua-parser-js": "^0.7.39",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-refresh": "^0.4",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
